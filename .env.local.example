# Supabase Configuration
# Copy this file to .env and replace with your actual Supabase project credentials

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Service role key for admin operations (not exposed to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Twilio WhatsApp Configuration
TWILIO_ACCOUNT_SID=your-twilio-account-sid
# Twilio (Legacy - To be removed)
# TWILIO_ACCOUNT_SID=...
# TWILIO_AUTH_TOKEN=...
# TWILIO_WHATSAPP_NUMBER=...

# Meta WhatsApp Cloud API
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=

# WhatsApp Test Mode - When enabled, all messages go to TEST_PHONE_NUMBER
WHATSAPP_TEST_MODE=true
TEST_PHONE_NUMBER=+911234567890

# SMS (MSG91) Configuration
SMS_TEST_MODE="false"
MSG91_AUTH_KEY="your_msg91_auth_key"
MSG91_TEMPLATE_WELCOME=""
MSG91_TEMPLATE_NEW_INQUIRY=""
MSG91_TEMPLATE_BIDDING_STARTED=""
MSG91_TEMPLATE_NEW_OFFER=""
MSG91_TEMPLATE_OFFER_ACCEPTED_BUYER=""
MSG91_TEMPLATE_OFFER_ACCEPTED_SELLER=""
MSG91_TEMPLATE_OFFER_REJECTED_SELLER=""
